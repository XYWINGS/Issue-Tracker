NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/issue-tracker
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:3000
# CLIENT_ORIGIN also supports comma-separated exact origins and wildcards:
# CLIENT_ORIGIN=http://localhost:3000,https://issue-tracker-*-xywingss-projects.vercel.app
COOKIE_SECURE=false
